# ========== 用户密钥配置 ==========
# 支持格式：key1,key2,key3 或 key1, key2, key3
SECRETS=server1_secret_key,server2_secret_key, server3_secret_key

# ========== SMTP 默认配置（发件人相关）==========
SMTP_SERVER=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@163.com
SMTP_PASSWORD=your_auth_code
SMTP_FROM=your_email@163.com

# ========== 管理员密钥（可选）==========
ADMIN_KEY=your_admin_key_here

# ========== 服务配置 ==========
PORT=5000
DEBUG=false
